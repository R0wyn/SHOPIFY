<section class="home-usp-bar color-{{ section.settings.color_scheme }}" id="home-usp-bar-{{ section.id }}" aria-label="USP balk">
<section class="home-usp-bar color-{{ section.settings.color_scheme }}" aria-label="USP balk">
  <div class="page-width home-usp-bar__inner">
    {% for block in section.blocks %}
      <div class="home-usp-bar__item" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <span class="home-usp-bar__icon" aria-hidden="true">{{ block.settings.icon }}</span>
        {% endif %}
        <span>{{ block.settings.text }}</span>
      </div>
    {% endfor %}
  </div>
</section>

<style>
  #home-usp-bar-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; border-bottom: 1px solid rgba(0,0,0,.08); }
  #home-usp-bar-{{ section.id }} .home-usp-bar__inner { display: grid; gap: 12px; grid-template-columns: repeat(1,minmax(0,1fr)); }
  #home-usp-bar-{{ section.id }} .home-usp-bar__item { display:flex; align-items:center; justify-content:center; gap:8px; font-size: .9rem; font-weight:600; text-align:center; }
  #home-usp-bar-{{ section.id }} .home-usp-bar__icon { font-size: 1rem; line-height: 1; }
  @media (min-width: 750px) { #home-usp-bar-{{ section.id }} .home-usp-bar__inner { grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0,1fr)); } }
  .home-usp-bar { padding: 10px 0; border-bottom: 1px solid rgba(0,0,0,.08); }
  .home-usp-bar__inner { display: grid; gap: 12px; grid-template-columns: repeat(1,minmax(0,1fr)); }
  .home-usp-bar__item { display:flex; align-items:center; justify-content:center; gap:8px; font-size: .9rem; font-weight:600; text-align:center; }
  .home-usp-bar__icon { font-size: 1rem; line-height: 1; }
  @media (min-width: 750px) { .home-usp-bar__inner { grid-template-columns: repeat(var(--usp-columns,4), minmax(0,1fr)); } }
</style>

{% schema %}
{
  "name": "Home USP-balk",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurschema", "default": "scheme-1" },
    { "type": "range", "id": "columns_desktop", "label": "Kolommen desktop", "min": 2, "max": 4, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding boven", "min": 0, "max": 30, "step": 2, "default": 10 },
    { "type": "range", "id": "padding_bottom", "label": "Padding onder", "min": 0, "max": 30, "step": 2, "default": 10 }
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurschema", "default": "scheme-1" }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icoon (emoji of kort teken)", "default": "✓" },
        { "type": "text", "id": "text", "label": "Tekst", "default": "Gratis verzending vanaf €50" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "Home USP-balk", "blocks": [{"type":"usp"},{"type":"usp"},{"type":"usp"},{"type":"usp"}] }]
}
{% endschema %}
