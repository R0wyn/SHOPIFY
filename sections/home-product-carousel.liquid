<section class="home-product-carousel color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="home-product-carousel__head">
      <h2>{{ section.settings.title }}</h2>
      {% if section.settings.collection != blank %}
        <a href="{{ section.settings.collection.url }}" class="link">{{ section.settings.link_label }}</a>
      {% endif %}
    </div>
    <div class="home-product-carousel__track" role="list">
      {% for product in section.settings.collection.products limit: section.settings.limit %}
        <article class="home-product-carousel__card" role="listitem">
          <a href="{{ product.url }}" class="home-product-carousel__image-wrap">
            {% if product.compare_at_price > product.price %}<span class="badge">Sale</span>{% endif %}
            {{ product.featured_image | image_url: width: 640 | image_tag: loading: 'lazy', alt: product.featured_image.alt | escape }}
          </a>
          <p class="home-product-carousel__vendor">{{ product.vendor }}</p>
          <h3><a href="{{ product.url }}">{{ product.title }}</a></h3>
          <div>{% render 'price', product: product %}</div>
        </article>
      {% else %}
        <p>Kies een collectie in de section-instellingen om producten te tonen.</p>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.home-product-carousel { padding: 36px 0; }
.home-product-carousel__head { display:flex; justify-content:space-between; gap:16px; align-items:end; margin-bottom:16px; }
.home-product-carousel__head h2 { margin:0; }
.home-product-carousel__track { display:grid; grid-auto-flow:column; grid-auto-columns:minmax(220px, 23%); gap:16px; overflow:auto; scroll-snap-type:x mandatory; padding-bottom:8px; }
.home-product-carousel__card { scroll-snap-align:start; border:1px solid rgba(0,0,0,.08); border-radius:14px; padding:10px; background:rgb(var(--color-background)); }
.home-product-carousel__image-wrap { position:relative; display:block; }
.home-product-carousel__image-wrap img { width:100%; height:auto; border-radius:10px; }
.home-product-carousel__vendor { margin:10px 0 4px; font-size:.8rem; text-transform:uppercase; opacity:.65; }
.home-product-carousel__card h3 { margin:0 0 8px; font-size:1rem; }
.badge { position:absolute; top:8px; left:8px; background:#d21f3c; color:#fff; padding:2px 8px; border-radius:999px; font-size:.72rem; }
@media(max-width:989px){ .home-product-carousel__track { grid-auto-columns:minmax(190px, 72%); } }
</style>

{% schema %}
{
  "name":"Home productcarousel",
  "settings":[
    {"type":"color_scheme","id":"color_scheme","label":"Kleurschema","default":"scheme-1"},
    {"type":"text","id":"title","label":"Titel","default":"Onze hardlopers"},
    {"type":"collection","id":"collection","label":"Collectie"},
    {"type":"text","id":"link_label","label":"Link label","default":"Bekijk alles"},
    {"type":"range","id":"limit","label":"Aantal producten","min":4,"max":12,"step":1,"default":8}
  ],
  "presets":[{"name":"Home productcarousel"}]
}
{% endschema %}
