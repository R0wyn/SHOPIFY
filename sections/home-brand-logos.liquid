<section class="home-brand-logos color-{{ section.settings.color_scheme }}" id="home-brand-logos-{{ section.id }}">
  <div class="page-width">
    <h2 class="{% if section.settings.center_heading %}is-centered{% endif %}">{{ section.settings.title }}</h2>
<section class="home-brand-logos color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <h2>{{ section.settings.title }}</h2>
    <div class="home-brand-logos__row" role="list">
      {% for block in section.blocks %}
        <a class="home-brand-logos__item" href="{{ block.settings.link | default: '#' }}" role="listitem" {{ block.shopify_attributes }}>
          {% if block.settings.logo != blank %}
            {{ block.settings.logo | image_url: width: 280 | image_tag: loading: 'lazy', alt: block.settings.name | escape }}
          {% else %}
            <span>{{ block.settings.name }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
#home-brand-logos-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
#home-brand-logos-{{ section.id }} h2 { margin:0 0 14px; }
#home-brand-logos-{{ section.id }} h2.is-centered { text-align:center; }
#home-brand-logos-{{ section.id }} .home-brand-logos__row { display:grid; grid-auto-flow:column; grid-auto-columns:minmax(120px,1fr); gap:12px; overflow:auto; }
#home-brand-logos-{{ section.id }} .home-brand-logos__item { display:flex; align-items:center; justify-content:center; min-height:72px; border:1px solid rgba(0,0,0,.08); border-radius:12px; padding:8px; background:rgb(var(--color-background)); }
#home-brand-logos-{{ section.id }} .home-brand-logos__item img { max-width:100%; height:auto; max-height:38px; object-fit:contain; }
.home-brand-logos { padding: 28px 0; }
.home-brand-logos h2 { margin:0 0 14px; }
.home-brand-logos__row { display:grid; grid-auto-flow:column; grid-auto-columns:minmax(120px,1fr); gap:12px; overflow:auto; }
.home-brand-logos__item { display:flex; align-items:center; justify-content:center; min-height:72px; border:1px solid rgba(0,0,0,.08); border-radius:12px; padding:8px; background:rgb(var(--color-background)); }
.home-brand-logos__item img { max-width:100%; height:auto; max-height:38px; object-fit:contain; }
</style>

{% schema %}
{
  "name":"Home merken",
  "settings":[
    {"type":"color_scheme","id":"color_scheme","label":"Kleurschema","default":"scheme-1"},
    {"type":"text","id":"title","label":"Titel","default":"Onze merken"},
    {"type":"checkbox","id":"center_heading","label":"Titel centreren","default": true},
    {"type":"range","id":"padding_top","label":"Padding boven","min":0,"max":120,"step":4,"default":28},
    {"type":"range","id":"padding_bottom","label":"Padding onder","min":0,"max":120,"step":4,"default":28}
  ],
  "blocks":[{"type":"brand","name":"Merk","settings":[{"type":"text","id":"name","label":"Merknaam","default":"MerinoPro"},{"type":"image_picker","id":"logo","label":"Logo"},{"type":"url","id":"link","label":"Link"}]}],
  "max_blocks": 20,
  "settings":[{"type":"color_scheme","id":"color_scheme","label":"Kleurschema","default":"scheme-1"},{"type":"text","id":"title","label":"Titel","default":"Onze merken"}],
  "blocks":[{"type":"brand","name":"Merk","settings":[{"type":"text","id":"name","label":"Merknaam","default":"MerinoPro"},{"type":"image_picker","id":"logo","label":"Logo"},{"type":"url","id":"link","label":"Link"}]}],
  "max_blocks": 12,
  "presets":[{"name":"Home merken"}]
}
{% endschema %}
