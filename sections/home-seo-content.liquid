<section class="home-seo-content color-{{ section.settings.color_scheme }}" id="home-seo-content-{{ section.id }}">
  <div class="page-width home-seo-content__inner{% if section.settings.center_heading %} is-centered{% endif %}">
    <h2>{{ section.settings.title }}</h2>
    <div class="rte">{{ section.settings.content }}</div>
  </div>
</section>

<style>
#home-seo-content-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
#home-seo-content-{{ section.id }} .home-seo-content__inner { border-top:1px solid rgba(0,0,0,.08); padding-top:24px; max-width: {{ section.settings.content_max_width }}px; }
#home-seo-content-{{ section.id }} .home-seo-content__inner.is-centered { margin: 0 auto; text-align:center; }
#home-seo-content-{{ section.id }} h2 { margin:0 0 12px; }
</style>

{% schema %}
{
  "name":"Home SEO tekst",
  "settings":[
    {"type":"color_scheme","id":"color_scheme","label":"Kleurschema","default":"scheme-1"},
    {"type":"checkbox","id":"center_heading","label":"Tekst centreren","default": false},
    {"type":"range","id":"content_max_width","label":"Max breedte content","min":700,"max":1400,"step":20,"default":1200},
    {"type":"text","id":"title","label":"Titel","default":"Werksokken kopen bij een specialist"},
    {"type":"richtext","id":"content","label":"Inhoud","default":"<p>Op zoek naar comfortabele en duurzame sokken? In onze specialistische webshop vind je werksokken, merino sokken en functionele modellen voor elk moment van de dag. Dankzij slimme materialen en pasvormen blijven je voeten droog, fris en ondersteund.</p>"},
    {"type":"range","id":"padding_top","label":"Padding boven","min":0,"max":120,"step":4,"default":36},
    {"type":"range","id":"padding_bottom","label":"Padding onder","min":0,"max":120,"step":4,"default":56}
  ],
  "presets":[{"name":"Home SEO tekst"}]
}
{% endschema %}
