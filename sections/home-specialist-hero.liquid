<section class="home-specialist-hero color-{{ section.settings.color_scheme }}" id="home-specialist-hero-{{ section.id }}">
  <div class="page-width home-specialist-hero__wrap{% if section.settings.center_content %} is-centered{% endif %}">
    <div class="home-specialist-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="home-specialist-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      <h1>{{ section.settings.heading }}</h1>
      {% if section.settings.subheading != blank %}
        <p class="home-specialist-hero__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
      <div class="home-specialist-hero__actions">
        {% for block in section.blocks %}
          <a
            class="button {% if block.settings.style == 'secondary' %}button-secondary{% else %}button-primary{% endif %}"
            href="{{ block.settings.link | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </a>
        {% endfor %}
      </div>
    </div>

    {% if section.settings.image != blank %}
      <div class="home-specialist-hero__media">
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', alt: section.settings.image.alt | default: section.settings.heading | escape }}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #home-specialist-hero-{{ section.id }} { padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__wrap { display:grid; gap:24px; align-items:center; }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__content { max-width: {{ section.settings.content_max_width }}px; }
  #home-specialist-hero-{{ section.id }} .is-centered .home-specialist-hero__content { margin: 0 auto; text-align: center; }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__eyebrow { text-transform: uppercase; letter-spacing:.08em; font-size:.78rem; margin:0 0 8px; opacity:.7; }
  #home-specialist-hero-{{ section.id }} h1 { margin:0 0 12px; font-size: clamp(2rem, 4vw, 3.2rem); }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__subheading { margin:0; }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__actions { margin-top:20px; display:flex; flex-wrap:wrap; gap:12px; }
  #home-specialist-hero-{{ section.id }} .is-centered .home-specialist-hero__actions { justify-content: center; }
  #home-specialist-hero-{{ section.id }} .home-specialist-hero__media img { width:100%; height:auto; border-radius:16px; box-shadow: 0 8px 24px rgba(0,0,0,.08); }
  @media(min-width:990px){
    #home-specialist-hero-{{ section.id }} .home-specialist-hero__wrap { grid-template-columns: {% if section.settings.image != blank %}1.1fr .9fr{% else %}1fr{% endif %}; gap:40px; }
    #home-specialist-hero-{{ section.id }} .is-centered.home-specialist-hero__wrap { grid-template-columns: 1fr; }
  }
</style>

{% schema %}
{
  "name": "Home specialist hero",
  "settings": [
    {"type":"color_scheme","id":"color_scheme","label":"Kleurschema","default":"scheme-1"},
    {"type":"checkbox","id":"center_content","label":"Centreer content","default": true},
    {"type":"range","id":"content_max_width","label":"Max breedte content","min":480,"max":1000,"step":20,"default":760},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Specialist in performance sokken"},
    {"type":"text","id":"heading","label":"Titel","default":"Sokken die comfort en prestaties samenbrengen"},
    {"type":"textarea","id":"subheading","label":"Subtitel","default":"Ontdek ons specialistische assortiment voor werk, wandelen, sport en dagelijks gebruik."},
    {"type":"image_picker","id":"image","label":"Afbeelding"},
    {"type":"range","id":"padding_top","label":"Padding boven","min":0,"max":120,"step":4,"default":44},
    {"type":"range","id":"padding_bottom","label":"Padding onder","min":0,"max":120,"step":4,"default":44}
  ],
  "blocks":[
    {"type":"cta","name":"CTA knop","settings":[{"type":"text","id":"label","label":"Label","default":"Shop heren"},{"type":"url","id":"link","label":"Link"},{"type":"select","id":"style","label":"Stijl","default":"primary","options":[{"value":"primary","label":"Primair"},{"value":"secondary","label":"Secundair"}]}]}
  ],
  "max_blocks": 3,
  "presets":[{"name":"Home specialist hero","blocks":[{"type":"cta"},{"type":"cta","settings":{"label":"Shop dames","style":"secondary"}}]}]
}
{% endschema %}
